{
  "name": "split-flap-elements",
  "version": "0.2.0",
  "description": "Configurable, accessible split-flap Web Components.",
  "type": "module",
  "license": "MIT",
  "author": "Gabe Albert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabeosx/split-flap-elements.git"
  },
  "homepage": "https://gabeosx.github.io/split-flap-elements/",
  "bugs": {
    "url": "https://github.com/gabeosx/split-flap-elements/issues"
  },
  "keywords": [
    "split-flap",
    "web-components",
    "custom-elements",
    "departure-board",
    "animation",
    "accessible",
    "flip-clock"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.14"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11"
    }
  },
  "packageManager": "npm@11.17.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./board": {
      "types": "./dist/board.d.ts",
      "import": "./dist/board.js"
    },
    "./cell": {
      "types": "./dist/cell.d.ts",
      "import": "./dist/cell.js"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "customElements": "./custom-elements.json",
  "files": [
    "dist",
    "custom-elements.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "dev": "npm run demo:build && vite site --host 127.0.0.1",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:visual": "playwright test tests/visual.spec.ts",
    "demo:build": "npm run build && node scripts/build-demo.mjs",
    "demo:gif": "npm run build && node scripts/capture-demo.mjs",
    "demo:social": "npm run build && node scripts/capture-social.mjs",
    "pack:check": "npm run build && node scripts/check-package.mjs",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run test:browser && npm run pack:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.1.0",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  }
}
